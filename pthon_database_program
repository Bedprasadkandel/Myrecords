import sqlite3
conn=sqlite3.connect('Database2.db')
cursor=conn.cursor()
cursor.execute('''
   CREATE TABLE IF NOT EXISTS students(
        id INTEGER PRIMARY KEY,
        username TEXT NOT NULL,
        age INTEGER,
        email TEXT UNIQUE
    )

''')
conn.commit()

